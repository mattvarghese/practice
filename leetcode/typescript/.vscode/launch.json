{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Current TS Test",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/jest",
            "args": [
                "${file}",
                "--config",
                "${workspaceFolder}/jest.config.ts",
                "--runInBand"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}