{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug (from .vscode/launch.json)",
            "type": "cppdbg",
            "request": "launch",
            // This token tells VSCode to automatically track whichever target 
            // you have currently selected in your bottom CMake status bar
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "$PATH:${command:cmake.launchTargetDirectory}"
                }
            ],
            // Forces GDB onto a true TTY, silences "Failed to set controlling terminal" warning.
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "targetArchitecture": "x64"
        }
    ]
}